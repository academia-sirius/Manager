// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Centro {
  id          Int      @id @default(autoincrement())
  email       String   @unique
  senha       String
  nome        String   @unique
  nif         String   @unique
  tipo        String
  logo        String?
  slogan      String?
  descricao   String?
  localizacao String?
  telefone    String?
  createdAt   DateTime @default(now())
  turmas      Turma[]
}

model Turma {
  id            Int           @id @default(autoincrement())
  nome          String
  duracao       String
  tipoFormacao  String
  responsavel   String
  centroId      Int
  centro        Centro        @relation(fields: [centroId], references: [id])
  estagiarios   Estagiario[]
  createdAt     DateTime      @default(now())
}

model Estagiario {
  id              Int      @id @default(autoincrement())
  nome            String
  email           String?
  telefone        String?
  
  // Identificação e Contexto
  classe          String?
  dataInicio      String?
  dataFim         String?
  totalHoras      String?
  
  // Entidade de Acolhimento
  empresaNome     String?
  empresaMorada   String?
  empresaTelefone String?
  empresaEmail    String?
  orientadorNome   String?
  orientadorFuncao String?
  
  // Matriz de Avaliação (15 Parâmetros) - Numéricos (0 a 20)
  crit1_assiduidade      Float? @default(10)
  crit2_pontualidade     Float? @default(10)
  crit3_disciplina       Float? @default(10)
  crit4_empenho          Float? @default(10)
  crit5_maturidade       Float? @default(10)
  crit6_criatividade     Float? @default(10)
  crit7_comunicacao      Float? @default(10)
  crit8_trabalho_equipa  Float? @default(10)
  crit9_apresentacao     Float? @default(10)
  crit10_conhecimentos   Float? @default(10)
  crit11_autoconfianca   Float? @default(10)
  crit12_relacao_sup     Float? @default(10)
  crit13_relacao_col     Float? @default(10)
  crit14_iniciativa      Float? @default(10)
  crit15_relatorio       Float? @default(10)
  
  // Observações e Validação
  observacoes     String?
  notaEmpresa     Float?
  notaEscola      Float?
  
  registrosDiarios RegistroDiario[]
  
  turmaId         Int
  turma           Turma    @relation(fields: [turmaId], references: [id])
  createdAt       DateTime @default(now())
}

model RegistroDiario {
  id                      Int      @id @default(autoincrement())
  data                    DateTime @default(now())
  presenca                Boolean  @default(true)
  atraso_minutos          Int      @default(0)
  observacao_comportamental String?
  
  estagiarioId            Int
  estagiario              Estagiario @relation(fields: [estagiarioId], references: [id])
}

model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  email     String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}
